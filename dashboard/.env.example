# Copy to dashboard/.env and fill in values for local Evidence dev.
# This file is gitignored — never commit real credentials.

# DuckDB (local dev)
EVIDENCE_SOURCE__DEFAULT__CONNECTOR=duckdb
EVIDENCE_SOURCE__DEFAULT__FILENAME=../concrete_data_dev.duckdb

# BigQuery (uncomment for prod testing locally)
# EVIDENCE_SOURCE__DEFAULT__CONNECTOR=bigquery
# EVIDENCE_SOURCE__DEFAULT__PROJECT_ID=your-gcp-project-id
# EVIDENCE_SOURCE__DEFAULT__DATASET=nyc_311_marts
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json
